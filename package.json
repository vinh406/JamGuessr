{
  "name": "vite-react-template",
  "private": true,
  "description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
  "type": "module",
  "scripts": {
    "build": "tsgo -b && vite build",
    "cf-typegen": "wrangler types",
    "check": "tsgo && vite build && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "dev": "vite --host 127.0.0.1",
    "lint": "oxlint .",
    "fmt": "oxfmt",
    "preview": "npm run build && wrangler dev --ip 127.0.0.1",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.11.2",
    "@tailwindcss/vite": "^4.3.0",
    "better-auth": "^1.6.16",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "lastfm-ts-api": "^2.6.2",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^5.5.7",
    "react-router": "^7.17.0",
    "sonner": "^2.0.7",
    "spotify-url-info": "^3.3.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260610.1",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "vite": "^8.0.16",
    "wrangler": "^4.99.0"
  },
  "lint-staged": {
    "*.{ts,tsx,css,json,md}": "oxfmt",
    "*.{ts,tsx}": "oxlint"
  },
  "cloudflare": {
    "label": "Vite React Template",
    "products": [
      "Workers"
    ],
    "categories": [],
    "preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/532a5378-9717-4964-385b-5fafd2160200/public",
    "preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/ec7f4be5-d1d6-4e94-0851-126341745400/preview",
    "publish": true
  }
}
